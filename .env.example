# ========================================================
# AI Trading System IDX - Configuration
# ========================================================
# Copy this file to .env and adjust values accordingly
# cp .env.example .env

# ---- Trading Mode ----
PAPER_TRADING=TRUE
# Set to FALSE only when ready for live trading with real money

# ---- Capital & Portfolio ----
INITIAL_CAPITAL=10000000
# Starting capital in IDR (default: Rp 10.000.000)

# ---- Risk Management ----
MAX_RISK_PER_TRADE=0.02
# Maximum risk per single trade (2% of capital)
MAX_DAILY_LOSS=0.05
# Maximum daily loss allowed (5% of capital)
MAX_OPEN_POSITIONS=5
# Maximum number of concurrent open positions
MIN_RISK_REWARD_RATIO=2.0
# Minimum risk-reward ratio required for trade entry
TRAILING_STOP_MULTIPLIER=2.0
# Trailing stop loss ATR multiplier

# ---- AI Model ----
AI_PROBABILITY_THRESHOLD=0.75
# Minimum AI probability required for BUY signal
MODEL_PATH=ml/models/ensemble_model.joblib

# ---- Market Scanning ----
SCAN_TICKERS=BBCA.JK,BBRI.JK,BMRI.JK,BBNI.JK,BBTN.JK,BRIS.JK,ASII.JK,TLKM.JK,UNVR.JK,ICBP.JK,INDF.JK,KLBF.JK,SIDO.JK,ANTM.JK,INCO.JK,PTBA.JK,ADRO.JK,ITMG.JK,PGAS.JK,AKRA.JK,CPIN.JK,SMGR.JK,INKP.JK,BRPT.JK,UNTR.JK,AMRT.JK,MAPI.JK,EXCL.JK,ISAT.JK,JSMR.JK,TOWR.JK,CTRA.JK,SMRA.JK,GOTO.JK,ACES.JK,ADMR.JK,ESSA.JK,MBMA.JK,AMMN.JK,JPFA.JK
# Comma-separated list of IDX tickers to scan (LQ45 stocks with .JK suffix)
SCAN_INTERVAL_MINUTES=60
# How often to run the market scan (in minutes)
DATA_LOOKBACK_DAYS=365
# How many days of historical data to fetch

# ---- Telegram Notifications ----
TELEGRAM_BOT_TOKEN=
# Get from @BotFather on Telegram
TELEGRAM_CHAT_ID=
# Your Telegram chat ID or group ID
TELEGRAM_ENABLED=FALSE

# ---- Database ----
DATABASE_URL=sqlite:///data/trading.db
# For PostgreSQL: postgresql://user:password@host:port/dbname
# For Supabase: postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# ---- Logging ----
LOG_LEVEL=INFO
LOG_FILE=logs/trading.log

# ---- Circuit Breaker ----
CIRCUIT_BREAKER_THRESHOLD=3
# Number of consecutive API errors before disabling trading
EXTREME_VOLATILITY_ATR_MULTIPLIER=3.0
# ATR multiplier to detect extreme volatility
